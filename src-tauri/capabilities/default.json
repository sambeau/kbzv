{
  "identifier": "default",
  "description": "Default capabilities for KBZV",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-home-read-recursive",
    "kbz-fs-read",
    "allow-validate-project",
    "allow-read-text-file",
    "allow-read-directory",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": true
        }
      ]
    }
  ]
}
